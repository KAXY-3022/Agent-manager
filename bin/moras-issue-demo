  <div class="toast" id="toast"></div>
  <script>
    const state = { view: "board", itemFilter: "", stateFilter: "open", relationFilter: "", boardRelationFilter: "related" };
    const boardColumns = [
      {id:"wip", title:"WIP"},
      {id:"under_review", title:"Under Review"},
      {id:"reviewing", title:"Reviewing"},
      {id:"reviewed", title:"Reviewed"}
    ];
    const $ = (id) => document.getElementById(id);
    const preferredTheme = () => localStorage.getItem("moras-runner-theme") || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    const preferredSidebarCollapsed = () => localStorage.getItem("moras-runner-sidebar-collapsed") === "1";
    function applyTheme(theme) {
      document.documentElement.dataset.theme = theme;
      localStorage.setItem("moras-runner-theme", theme);
      const btn = $("theme-toggle");
      if (btn) btn.textContent = theme === "dark" ? "Light" : "Dark";
    }
    function applySidebarCollapsed(collapsed) {
      const shell = document.querySelector(".shell");
      const reveal = $("sidebar-reveal");
      const hide = $("sidebar-hide");
      if (shell) shell.classList.toggle("sidebar-collapsed", collapsed);
      if (reveal) {
        reveal.classList.toggle("hidden", !collapsed);
        reveal.setAttribute("aria-expanded", String(!collapsed));
      }
      if (hide) {
        hide.setAttribute("aria-expanded", String(!collapsed));
      }
      localStorage.setItem("moras-runner-sidebar-collapsed", collapsed ? "1" : "0");
      requestAnimationFrame(fitKanbanToWindow);
    }
    applyTheme(preferredTheme());
    applySidebarCollapsed(preferredSidebarCollapsed());
    const esc = (v) => String(v ?? "").replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    const badgeClass = (value) => {
      const text = String(value ?? "").toLowerCase();
      if (["done", "open", "ok", "succeeded", "posted", "merged", "reviewed"].includes(text)) return "ok";
      if (["failed", "closed", "unauthorized"].includes(text)) return "bad";
      if (["queued", "running", "ignored", "duplicate", "local", "stale", "draft"].includes(text)) return "warn";
      return "";
    };
    const badge = (value) => `<span class="badge ${badgeClass(value)}">${esc(value || "-")}</span>`;
    const marker = (type) => type === "pull_request" ? "PR" : "issue";
    const itemHref = (item) => item.url ? `<a class="target-link" href="${esc(item.url)}" target="_blank" rel="noreferrer">${esc(marker(item.item_type))}#${esc(item.number)}</a>` : `${esc(marker(item.item_type))}#${esc(item.number)}`;
    const titleHref = (item) => item.url ? `<a href="${esc(item.url)}" target="_blank" rel="noreferrer">${esc(item.title || "(untitled)")}</a>` : esc(item.title || "(untitled)");
    const relationBadges = (item) => {
      const labels = item.relationship_labels || [];
      if (!labels.length) return '<span class="muted">-</span>';
      return `<div class="relation-list">${labels.map(label => `<span class="badge rel-${esc(label)}">${esc(label)}</span>`).join("")}</div>`;
    };
    const reviewBadge = (item) => {
      if (item.item_type !== "pull_request") return '<span class="muted">-</span>';
      const status = item.review_status || {};
      if (!status.label) return '<span class="muted">-</span>';
      const bits = [];
      if (status.latest_at) bits.push(`reviewed ${status.latest_at}`);
      if (status.posted_at) bits.push(`posted ${status.posted_at}`);
      if (status.stale && status.reviewed_head_sha && status.current_head_sha) bits.push(`head ${status.reviewed_head_sha.slice(0, 8)} -> ${status.current_head_sha.slice(0, 8)}`);
      const title = bits.length ? ` title="${esc(bits.join(" | "))}"` : "";
      return `<span${title}>${badge(status.label)}</span>`;
    };
    const jobStatusIcon = (item) => {
      const job = item.job_status || {};
      if (!job.active) return "";
      const status = String(job.status || "").toLowerCase();
      const label = status === "running" ? "AI running" : status === "queued" ? "AI queued" : `AI ${status || "job"}`;
      const title = `${job.kind_label || "AI job"} ${status || "active"}${job.updated_at ? ` · ${job.updated_at}` : ""}`;
      return `<span class="job-indicator ${esc(status || "queued")}" title="${esc(title)}" aria-label="${esc(title)}"><span class="job-dot" aria-hidden="true"></span><span class="job-text">${esc(label)}</span></span>`;
    };
    const jobStatusCell = (item) => jobStatusIcon(item) || '<span class="muted">-</span>';
    const hasReviewRequest = (item) => {
      const reviews = (item.snapshot && item.snapshot.reviews) || [];
      return item.has_review_request || reviews.some(r => String(r.state || "").toUpperCase() === "REQUEST_REVIEW");
    };
    const itemKey = (item) => `${item.repo}:${item.item_type}:${item.number}`;
    const relationshipMatches = (item, relation) => {
      if (!relation || relation === "all") return true;
      const rel = item.relationships || {};
      const relationMap = {
        related: "related_to_me",
        created: "created_by_me",
        assigned: "assigned_to_me",
        review_requested: "review_requested_from_me",
        participating: "participating"
      };
      const key = relationMap[relation];
      return Boolean(key && rel[key]);
    };
    const isWipTitle = (item) => /(^|\s)(wip|draft)\b/i.test(item.title || "");
    const boardColumnFor = (item) => {
      const rel = item.relationships || {};
      const review = item.review_status || {};
      if (item.item_type === "issue") return "";
      if (review.reviewed && !review.stale) return "reviewed";
      if (rel.review_requested_from_me) return "reviewing";
      if (rel.created_by_me || rel.assigned_to_me) {
        if (!isWipTitle(item) && hasReviewRequest(item)) return "under_review";
        return "wip";
      }
      if (rel.participating) return "reviewing";
      return "wip";
    };
    const cardRelationClass = (item) => {
      const rel = item.relationships || {};
      if (rel.created_by_me) return "rel-created";
      if (rel.assigned_to_me) return "rel-assigned";
      if (rel.review_requested_from_me) return "rel-review";
      if (rel.participating) return "rel-participating";
      return "rel-linked";
    };
    const indexItems = (items) => {
      const byKey = new Map();
      const prsByIssue = new Map();
      for (const item of items) {
        byKey.set(`${item.repo}:${item.item_type}:${item.number}`, item);
      }
      for (const item of items) {
        if (item.item_type !== "pull_request") continue;
        for (const issueNumber of ((item.snapshot && item.snapshot.linked_issues) || [])) {
          const key = `${item.repo}:${issueNumber}`;
          if (!prsByIssue.has(key)) prsByIssue.set(key, []);
          prsByIssue.get(key).push(item);
        }
      }
      return {byKey, prsByIssue};
    };
    const linkedItemsForBoard = (item, indexes) => {
      if (item.item_type === "issue") {
        const directPrs = ((item.snapshot && item.snapshot.linked_prs) || [])
          .map(number => indexes.byKey.get(`${item.repo}:pull_request:${number}`))
          .filter(Boolean);
        return [...directPrs, ...(indexes.prsByIssue.get(`${item.repo}:${item.number}`) || [])];
      }
      return ((item.snapshot && item.snapshot.linked_issues) || [])
        .map(number => indexes.byKey.get(`${item.repo}:issue:${number}`))
        .filter(Boolean);
    };
    const boardVisibleItems = (items, indexes) => {
      const active = items.filter(i => i.state === "open");
      if (!state.boardRelationFilter) return active;
      const included = new Set();
      for (const item of active) {
        if (!relationshipMatches(item, state.boardRelationFilter)) continue;
        included.add(itemKey(item));
        if (state.boardRelationFilter === "related") {
          for (const linked of linkedItemsForBoard(item, indexes)) included.add(itemKey(linked));
        }
      }
      return active.filter(item => included.has(itemKey(item)));
    };
    const itemTinyLink = (item) => item ? itemHref(item) : "";
    const cardLinks = (item, indexes) => {
      const parts = [];
      if (item.item_type === "issue") {
        const linked = [...((item.snapshot && item.snapshot.linked_prs) || []).map(number => indexes.byKey.get(`${item.repo}:pull_request:${number}`)).filter(Boolean), ...(indexes.prsByIssue.get(`${item.repo}:${item.number}`) || [])];
        const unique = [...new Map(linked.map(pr => [pr.number, pr])).values()];
        if (unique.length) parts.push(`PR ${unique.map(itemTinyLink).join(" ")}`);
      } else {
        const linkedIssues = (item.snapshot && item.snapshot.linked_issues) || [];
        if (linkedIssues.length) {
          const links = linkedIssues.map(number => indexes.byKey.get(`${item.repo}:issue:${number}`) || {item_type:"issue", number, url:`${item.url.replace(/\/pulls\/\d+$/, `/issues/${number}`)}`});
          parts.push(`Issue ${links.map(itemTinyLink).join(" ")}`);
        }
      }
      return parts.length ? `<div class="work-card-links">${parts.join("")}</div>` : "";
    };
    const workCard = (item, indexes) => `<div class="work-card ${cardRelationClass(item)}">
      <div class="work-card-meta">${badge(marker(item.item_type))} ${itemHref(item)} ${badge(item.state)} ${reviewBadge(item)} ${jobStatusIcon(item)}</div>
      <div class="work-card-title">${titleHref(item)}</div>
      <div class="work-card-meta">${relationBadges(item)}</div>
      ${cardLinks(item, indexes)}
    </div>`;
    const issueCard = (item, indexes) => `<div class="issue-card ${cardRelationClass(item)}">
      <div class="work-card-meta">${itemHref(item)} ${jobStatusIcon(item)}</div>
      <div class="issue-card-title">${titleHref(item)}</div>
      ${cardLinks(item, indexes)}
    </div>`;
    function fitKanbanToWindow() {
      const board = $("board");
      const kanban = $("kanban-board");
      if (!board || !kanban || board.classList.contains("hidden")) return;
      const bodies = [...kanban.querySelectorAll(".kanban-body")];
      const cardCounts = bodies.map(body => [...body.children].filter(child => child.classList.contains("work-card")).length);
      const maxCards = Math.max(1, ...cardCounts);
      const bodyHeights = bodies.map(body => body.clientHeight).filter(Boolean);
      if (bodyHeights.length) {
        const gap = maxCards >= 8 ? 3 : maxCards >= 5 ? 5 : 8;
        const available = Math.min(...bodyHeights) - (gap * 2) - (gap * Math.max(0, maxCards - 1));
        const cardHeight = Math.max(16, Math.min(112, Math.floor(available / maxCards)));
        board.style.setProperty("--board-card-gap", `${gap}px`);
        board.style.setProperty("--board-card-height", `${cardHeight}px`);
        board.classList.toggle("density-micro", cardHeight < 44);
        board.classList.toggle("density-compact", cardHeight >= 44 && cardHeight < 72);
      }
      const issueBody = $("kanban-issues");
      if (issueBody) {
        const issueCount = [...issueBody.children].filter(child => child.classList.contains("issue-card")).length;
        if (issueCount > 0) {
          const width = Math.max(1, issueBody.clientWidth);
          const minWidth = issueCount > 8 ? 160 : 190;
          const columns = Math.max(1, Math.min(issueCount, Math.floor(width / minWidth) || 1));
          const rows = Math.ceil(issueCount / columns);
          const maxBodyHeight = 142;
          const gap = 6;
          const cardHeight = Math.max(30, Math.min(52, Math.floor((maxBodyHeight - 12 - (gap * Math.max(0, rows - 1))) / rows)));
          board.style.setProperty("--issue-columns", String(columns));
          board.style.setProperty("--issue-card-height", `${cardHeight}px`);
        }
      }
    }
    const toast = (msg) => { const t = $("toast"); t.textContent = msg; t.style.display = "block"; setTimeout(() => t.style.display = "none", 4200); };
    async function api(path, options = {}) {
      const res = await fetch(path, options);
      const text = await res.text();
      let data = {};
      try { data = text ? JSON.parse(text) : {}; } catch { data = { error: text }; }
      if (!res.ok) throw new Error(data.error || `${res.status} ${res.statusText}`);
      return data;
    }
    function table(headers, rows, emptyText = "No data") {
      if (!rows.length) return `<div class="empty">${esc(emptyText)}</div>`;
      return `<table><thead><tr>${headers.map(h => `<th style="width:${h.w || "auto"}">${esc(h.t)}</th>`).join("")}</tr></thead><tbody>${rows.join("")}</tbody></table>`;
    }
    function renderLog(events) {
      if (!events.length) return `<div class="empty">No tracked changes</div>`;
      return events.map(e => `<div class="logline">
        <div class="mono muted">${esc(e.created_at)}</div>
        <div>${badge(e.event_kind)}</div>
        <div><strong>${esc(e.repo)} ${itemHref(e)}</strong>${e.title ? ` · ${titleHref(e)}` : ""}<br><span class="muted">${esc(e.summary)}</span></div>
      </div>`).join("");
    }
    async function loadStatus() {
      const data = await api("/api/status");
      $("runtime").textContent = data.config.runtime || "-";
      $("monitor").textContent = `${data.config.monitor_seconds}s`;
      $("webhook-url").textContent = data.config.webhook_url || "-";
      $("ngrok-url").textContent = data.config.ngrok_public_url ? `${data.config.ngrok_public_url}/gitea` : "-";
      $("metric-prs").textContent = data.counts.tracked_open.pull_request || 0;
      $("metric-issues").textContent = data.counts.tracked_open.issue || 0;
      $("metric-jobs").textContent = data.counts.jobs.done || 0;
      $("metric-jobs-sub").textContent = Object.entries(data.counts.jobs).map(([k,v]) => `${k}:${v}`).join("  ") || "No jobs";
      $("metric-last").textContent = data.counts.latest_tracked_event_at || "-";
      $("last-refresh").textContent = `Updated ${new Date().toLocaleTimeString()}`;
    }
    async function loadChanges() {
      const params = new URLSearchParams({limit: "80"});
      if (state.stateFilter) params.set("state", state.stateFilter);
      const data = await api(`/api/changes?${params.toString()}`);
      $("changes-table").innerHTML = renderLog(data.events);
      $("overview-changes").innerHTML = renderLog(data.events.slice(0, 8));
    }
    async function loadItems() {
      const params = new URLSearchParams({limit: "80"});
      if (state.itemFilter) params.set("type", state.itemFilter);
      if (state.stateFilter) params.set("state", state.stateFilter);
      if (state.relationFilter) params.set("relation", state.relationFilter);
      const data = await api(`/api/items?${params.toString()}`);
      const rows = data.items.map(i => `<tr>
        <td class="mono" style="width:150px">${esc(i.changed_at)}</td>
        <td style="width:90px">${badge(marker(i.item_type))}</td>
        <td style="width:115px">${itemHref(i)}</td>
        <td class="title-cell">${titleHref(i)}</td>
        <td style="width:85px">${badge(i.state)}</td>
        <td style="width:105px">${reviewBadge(i)}</td>
        <td style="width:105px">${jobStatusCell(i)}</td>
        <td style="width:155px">${relationBadges(i)}</td>
      </tr>`);
      $("items-table").innerHTML = table([
        {t:"Changed", w:"150px"}, {t:"Type", w:"90px"}, {t:"Target", w:"120px"}, {t:"Title"}, {t:"State", w:"85px"}, {t:"Review", w:"105px"}, {t:"AI", w:"105px"}, {t:"Relation", w:"155px"}
      ], rows, "No tracked items");
      $("overview-items").innerHTML = table([
        {t:"Type", w:"90px"}, {t:"Target", w:"120px"}, {t:"Title"}, {t:"State", w:"85px"}, {t:"Review", w:"105px"}, {t:"AI", w:"105px"}, {t:"Relation", w:"155px"}, {t:"Changed", w:"150px"}
      ], data.items.slice(0, 10).map(i => `<tr>
        <td>${badge(marker(i.item_type))}</td>
        <td>${itemHref(i)}</td>
        <td class="title-cell">${titleHref(i)}</td>
        <td>${badge(i.state)}</td>
        <td>${reviewBadge(i)}</td>
        <td>${jobStatusCell(i)}</td>
        <td>${relationBadges(i)}</td>
        <td class="mono muted">${esc(i.changed_at)}</td>
      </tr>`), "No tracked issues or PRs");
    }
    async function loadBoard() {
      const data = await api("/api/items?limit=200&state=open");
      const active = data.items.filter(i => i.state === "open");
      const indexes = indexItems(active);
      const visible = boardVisibleItems(data.items, indexes);
      const prItems = visible.filter(item => item.item_type === "pull_request");
      const issueItems = visible.filter(item => item.item_type === "issue");
      const groups = Object.fromEntries(boardColumns.map(col => [col.id, []]));
      for (const item of prItems) {
        const col = boardColumnFor(item);
        if (groups[col]) groups[col].push(item);
      }
      $("kanban-board").innerHTML = boardColumns.map(col => {
        const items = groups[col.id] || [];
        return `<section class="kanban-column">
          <div class="kanban-head"><span>${esc(col.title)}</span><span class="badge">${items.length}</span></div>
          <div class="kanban-body">${items.length ? items.map(item => workCard(item, indexes)).join("") : '<div class="empty">No items</div>'}</div>
        </section>`;
      }).join("");
      $("kanban-issues-count").textContent = issueItems.length;
      $("kanban-issues").innerHTML = issueItems.length ? issueItems.map(item => issueCard(item, indexes)).join("") : '<div class="empty">No issues</div>';
      requestAnimationFrame(fitKanbanToWindow);
    }
    async function loadJobs() {
      const data = await api("/api/jobs?limit=80");
      const rows = data.jobs.map(j => `<tr>
        <td class="mono" style="width:150px">${esc(j.created_at)}</td>
        <td style="width:90px">${badge(j.status)}</td>
        <td style="width:95px">${esc(j.kind)}</td>
        <td class="mono">${esc(j.dedupe_key)}</td>
        <td style="width:70px">${esc(j.retry_count)}</td>
      </tr>`);
      $("jobs-table").innerHTML = table([{t:"Created",w:"150px"},{t:"Status",w:"90px"},{t:"Kind",w:"95px"},{t:"Key"},{t:"Retry",w:"70px"}], rows, "No jobs");
    }
    async function loadDeliveries() {
      const data = await api("/api/deliveries?limit=80");
      const rows = data.deliveries.map(d => `<tr>
        <td class="mono" style="width:150px">${esc(d.created_at)}</td>
        <td style="width:90px">${badge(d.status)}</td>
        <td style="width:150px">${esc(d.event_type)}</td>
        <td class="mono">${esc(d.dedupe_key)}</td>
        <td>${esc(d.summary)}</td>
      </tr>`);
      $("deliveries-table").innerHTML = table([{t:"Created",w:"150px"},{t:"Status",w:"90px"},{t:"Event",w:"150px"},{t:"Key"},{t:"Summary"}], rows, "No deliveries");
    }
    async function loadTasks() {
      const data = await api("/api/tasks?limit=80");
      const rows = data.tasks.map(t => `<tr>
        <td class="mono" style="width:150px">${esc(t.created_at)}</td>
        <td style="width:95px">${badge(t.item_type === "pull_request" ? "PR" : "issue")}</td>
        <td style="width:100px">${t.url ? `<a class="target-link" href="${esc(t.url)}" target="_blank" rel="noreferrer">#${esc(t.target_index)}</a>` : `#${esc(t.target_index)}`}</td>
        <td class="title-cell">${t.url ? `<a href="${esc(t.url)}" target="_blank" rel="noreferrer">${esc(t.title || "(untitled)")}</a>` : esc(t.title || "(untitled)")}</td>
        <td style="width:90px">${badge(t.runtime_status || t.runtime_used)}</td>
        <td style="width:75px">${t.posted ? badge("posted") : badge("local")}</td>
      </tr>`);
      $("tasks-table").innerHTML = table([{t:"Created",w:"150px"},{t:"Type",w:"95px"},{t:"Target",w:"105px"},{t:"Title"},{t:"Runtime",w:"90px"},{t:"Post",w:"75px"}], rows, "No task packages");
    }
    async function refreshAll() {
      try {
        await loadStatus();
        await Promise.all([loadBoard(), loadChanges(), loadItems(), loadJobs(), loadDeliveries(), loadTasks()]);
      } catch (err) { toast(err.message); }
    }
    function setView(view) {
      state.view = view;
      document.querySelectorAll(".view").forEach(el => el.classList.toggle("hidden", el.id !== view));
      document.querySelectorAll(".nav button").forEach(btn => btn.classList.toggle("active", btn.dataset.view === view));
      $("view-title").textContent = document.querySelector(`.nav button[data-view="${view}"]`).textContent;
      if (view === "board") requestAnimationFrame(fitKanbanToWindow);
    }
    document.querySelectorAll(".nav button").forEach(btn => btn.addEventListener("click", () => setView(btn.dataset.view)));
    document.querySelectorAll("[data-item-filter]").forEach(btn => btn.addEventListener("click", async () => {
      state.itemFilter = btn.dataset.itemFilter;
      document.querySelectorAll("[data-item-filter]").forEach(x => x.classList.toggle("active", x === btn));
      await loadItems();
    }));
    document.querySelectorAll("[data-state-filter]").forEach(btn => btn.addEventListener("click", async () => {
      state.stateFilter = btn.dataset.stateFilter;
      document.querySelectorAll("[data-state-filter]").forEach(x => x.classList.toggle("active", x === btn));
      await Promise.all([loadBoard(), loadItems(), loadChanges()]);
    }));
    document.querySelectorAll("[data-relation-filter]").forEach(btn => btn.addEventListener("click", async () => {
      state.relationFilter = btn.dataset.relationFilter;
      document.querySelectorAll("[data-relation-filter]").forEach(x => x.classList.toggle("active", x === btn));
      await loadItems();
    }));
    document.querySelectorAll("[data-board-relation-filter]").forEach(btn => btn.addEventListener("click", async () => {
      state.boardRelationFilter = btn.dataset.boardRelationFilter;
      document.querySelectorAll("[data-board-relation-filter]").forEach(x => x.classList.toggle("active", x === btn));
      await loadBoard();
    }));
    $("theme-toggle").addEventListener("click", () => {
      applyTheme(document.documentElement.dataset.theme === "dark" ? "light" : "dark");
    });
    $("sidebar-reveal").addEventListener("click", () => {
      applySidebarCollapsed(false);
    });
    $("sidebar-hide").addEventListener("click", () => {
      applySidebarCollapsed(true);
    });
    $("refresh").addEventListener("click", refreshAll);
    $("monitor-once").addEventListener("click", async () => {
      try {
        const data = await api("/api/monitor-once", {method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({run_reviews:false})});
        toast(`Monitor complete: ${data.events.length} change(s)`);
        await refreshAll();
      } catch (err) { toast(err.message); }
    });
    $("sync-reviews").addEventListener("click", async () => {
      if (!confirm("Run PR review catch-up with runtime=none and no posting?")) return;
      try {
        const data = await api("/api/sync-review-requests", {method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({runtime:"none", no_post:true})});
        toast(`Catch-up complete: ${data.processed} job(s) processed`);
        await refreshAll();
      } catch (err) { toast(err.message); }
    });
    window.addEventListener("resize", () => requestAnimationFrame(fitKanbanToWindow));
    refreshAll();
    setInterval(refreshAll, 10000);
  </script>
</body>
</html>"""


def make_ui_handler(config: WebhookConfig):
    store = WebhookStateStore(config.state_db)

    class Handler(http.server.BaseHTTPRequestHandler):
        server_version = "MorasAgentRunnerUI/1.0"

        def do_GET(self) -> None:  # noqa: N802
            parsed = urllib.parse.urlparse(self.path)
            query = urllib.parse.parse_qs(parsed.query)
            try:
                if parsed.path == "/":
                    self._send(200, UI_HTML.encode("utf-8"), "text/html; charset=utf-8")
                    return
                if parsed.path == "/api/status":
                    payload = {
                        "config": config_summary(config),
                        "counts": store.summary_counts(),
                        "task_count": len(iter_records()),
                    }
                    self._json(200, payload)
                    return
                if parsed.path == "/api/changes":
                    raw_state = query_text(query, "state")
                    state_filter = raw_state if raw_state in {"all", "open", "inactive", "closed", "merged"} else None
                    self._json(
                        200,
                        {"events": store.recent_tracking_event_dicts(query_int(query, "limit", 50), state_filter)},
                    )
                    return
                if parsed.path == "/api/items":
                    raw_type = query_text(query, "type")
                    item_type = raw_type if raw_type in {"issue", "pull_request"} else None
                    raw_relation = query_text(query, "relation")
                    relation = raw_relation if raw_relation in {
                        "all",
                        "related",
                        "created",
                        "assigned",
                        "review_requested",
                        "participating",
                    } else None
                    raw_state = query_text(query, "state")
                    state_filter = raw_state if raw_state in {"all", "open", "inactive", "closed", "merged"} else None
                    self._json(
                        200,
                        {
                            "items": store.tracked_items_dicts(
                                query_int(query, "limit", 50),
                                item_type,
                                relation,
                                config.username,
                                state_filter,
                            )
                        },
                    )
                    return
                if parsed.path == "/api/jobs":
                    self._json(200, {"jobs": store.recent_jobs(query_int(query, "limit", 50))})
                    return
                if parsed.path == "/api/deliveries":
                    self._json(200, {"deliveries": store.recent_deliveries(query_int(query, "limit", 50))})
                    return
                if parsed.path == "/api/tasks":
                    self._json(200, {"tasks": task_record_dicts(query_int(query, "limit", 50))})
                    return
                self._json(404, {"error": "not found"})
            except Exception as exc:
                logging.exception("UI GET failed path=%s", self.path)
                self._json(500, {"error": str(exc)})

        def do_POST(self) -> None:  # noqa: N802
            parsed = urllib.parse.urlparse(self.path)
            try:
                body = self._read_json_body()
                if parsed.path == "/api/monitor-once":
                    updates = {
                        "monitor_pr_reviews": bool(body.get("run_reviews")),
                        "pr_auto_post": bool(body.get("post")),
                    }
                    runtime = body.get("runtime")
                    if runtime in {"auto", "claude", "codex", "none"}:
                        updates["runtime"] = runtime
                    action_config = WebhookConfig(**{**config.__dict__, **updates})
                    bridge = WebhookBridge(action_config, start_worker=False)
                    events = bridge.monitor_once()
                    processed = self._drain_jobs(bridge)
                    self._json(200, {"events": events, "processed": processed})
                    return
                if parsed.path == "/api/sync-review-requests":
                    updates: dict[str, Any] = {
                        "runtime": body.get("runtime") if body.get("runtime") in {"auto", "claude", "codex", "none"} else "none",
                        "pr_auto_post": bool(body.get("post")) and not bool(body.get("no_post", True)),
                    }
                    if isinstance(body.get("repo"), list):
                        updates["pr_review_poll_repos"] = tuple(str(item) for item in body["repo"] if item)
                    elif isinstance(body.get("repo"), str) and body.get("repo"):
                        updates["pr_review_poll_repos"] = (body["repo"],)
                    if isinstance(body.get("limit"), int) and body["limit"] > 0:
                        updates["pr_review_poll_limit"] = min(500, body["limit"])
                    action_config = WebhookConfig(**{**config.__dict__, **updates})
                    bridge = WebhookBridge(action_config, start_worker=False)
                    queued = bridge.sync_review_requests()
                    processed = self._drain_jobs(bridge)
                    self._json(200, {"queued": queued, "processed": processed})
                    return
                self._json(404, {"error": "not found"})
            except Exception as exc:
                logging.exception("UI POST failed path=%s", self.path)
                self._json(500, {"error": str(exc)})

        def log_message(self, fmt: str, *args: Any) -> None:
            logging.info("ui %s - %s", self.address_string(), fmt % args)

        def _drain_jobs(self, bridge: WebhookBridge) -> int:
            processed = 0
            while not bridge.jobs.empty():
                job = bridge.jobs.get()
                try:
                    bridge.process_job(job)
                    processed += 1
                finally:
                    bridge.jobs.task_done()
            return processed

        def _read_json_body(self) -> dict[str, Any]:
            try:
                length = int(self.headers.get("Content-Length", "0"))
            except ValueError:
                return {}
            if length <= 0:
                return {}
            body = self.rfile.read(min(length, MAX_WEBHOOK_BODY_BYTES))
            if not body:
                return {}
            data = json.loads(body.decode("utf-8"))
            return data if isinstance(data, dict) else {}

        def _json(self, status_code: int, payload: dict[str, Any]) -> None:
            self._send(status_code, json.dumps(payload, ensure_ascii=False).encode("utf-8"), "application/json; charset=utf-8")

        def _send(self, status_code: int, data: bytes, content_type: str) -> None:
            self.send_response(status_code)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(len(data)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(data)

    return Handler


def command_ui(args: argparse.Namespace) -> int:
    config = load_webhook_config(args.env, create_env=True)
    host = args.host or "127.0.0.1"
    port = args.port or DEFAULT_UI_PORT
    setup_webhook_logging(config)
    server = http.server.ThreadingHTTPServer((host, port), make_ui_handler(config))
    logging.info("MORAS runner UI listening on http://%s:%s", host, port)
    print(f"MORAS runner UI: http://{host}:{port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        logging.info("stopping MORAS runner UI")
    finally:
        server.shutdown()
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="moras-issue-demo",
        description="Personal local Gitea issue and PR agent-review demo.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    review = subparsers.add_parser("review", help="Fetch an issue and create a local read-only review package.")
    review.add_argument("issue", help="Gitea issue number, for example 442.")
    review.add_argument("--repo", default=DEFAULT_REPO, help=f"Gitea repo slug. Default: {DEFAULT_REPO}")
    review.add_argument(
        "--component",
        default=DEFAULT_COMPONENT,
        help=f"Local component directory used as the read-only agent root. Default: {DEFAULT_COMPONENT}",
    )
    review.add_argument(
        "--runtime",
        choices=("auto", "claude", "codex", "none"),
        default=os.environ.get("MORAS_ISSUE_DEMO_RUNTIME", "none"),
        help="Agent runtime. auto prefers claude, then codex, then none. Default: none.",
    )
    review.add_argument("--max-comments", type=int, default=20, help="Maximum recent comments to include.")
    review.add_argument("--post", action="store_true", help="Post successful agent issue reviews back to Gitea.")
    review.add_argument("--max-chars", type=int, default=12000, help="Maximum Gitea comment size to post.")
    review.add_argument("--timeout", type=int, default=1800, help="Agent runtime timeout in seconds.")
    review.set_defaults(func=command_review)

    pr_review = subparsers.add_parser("pr-review", help="Fetch a PR diff and create a local read-only review package.")
    pr_review.add_argument("pull", help="Gitea pull request number, for example 443.")
    pr_review.add_argument("--repo", default=DEFAULT_REPO, help=f"Gitea repo slug. Default: {DEFAULT_REPO}")
    pr_review.add_argument(
        "--component",
        default=DEFAULT_COMPONENT,
        help=f"Local component directory used as the read-only agent root. Default: {DEFAULT_COMPONENT}",
    )
    pr_review.add_argument(
        "--runtime",
        choices=("auto", "claude", "codex", "none"),
        default=os.environ.get("MORAS_ISSUE_DEMO_RUNTIME", "none"),
        help="Agent runtime. auto prefers claude, then codex, then none. Default: none.",
    )
    pr_review.add_argument("--max-comments", type=int, default=20, help="Maximum recent comments to include.")
    pr_review.add_argument(
        "--no-post",
        action="store_false",
        dest="post",
        help="Do not automatically post successful agent PR reviews back to Gitea.",
    )
    pr_review.add_argument("--max-chars", type=int, default=12000, help="Maximum Gitea comment size to post.")
    pr_review.add_argument(
        "--max-diff-chars",
        type=int,
        default=60000,
        help="Maximum diff characters to inline in the prompt. Full diff is still saved to diff.patch.",
    )
    pr_review.add_argument("--timeout", type=int, default=1800, help="Agent runtime timeout in seconds.")
    pr_review.set_defaults(post=True)
    pr_review.set_defaults(func=command_pr_review)

    post = subparsers.add_parser("post", help="Post a completed local review back to the Gitea issue or PR.")
    post.add_argument("task", help="Task directory, task id, or issue/PR number. Number resolves only when unambiguous.")
    post.add_argument("--repo", default=None, help="Override repo slug for resolving/posting.")
    post.add_argument("--issue", default=None, help="Override issue number for posting.")
    post.add_argument("--target", default=None, help="Override issue or PR number for posting.")
    post.add_argument("--type", choices=("issue", "pr"), default=None, help="Resolve numeric task as issue or PR.")
    post.add_argument("--suggested-only", action="store_true", help="Post only the Suggested Issue/PR Comment section.")
    post.add_argument("--dry-run", action="store_true", help="Print the comment body instead of posting.")
    post.add_argument("--max-chars", type=int, default=12000, help="Maximum Gitea comment size to post.")
    post.set_defaults(func=command_post)

    list_cmd = subparsers.add_parser("list", help="List local demo task packages.")
    list_cmd.add_argument("--limit", type=int, default=20)
    list_cmd.set_defaults(func=command_list)

    open_cmd = subparsers.add_parser("open", help="Open a saved task package for Codex Desktop follow-up.")
    open_cmd.add_argument("task", help="Task directory, task id, or issue/PR number. Number resolves to latest matching task.")
    open_cmd.add_argument("--repo", default=None, help="Override repo slug for resolving numeric tasks.")
    open_cmd.add_argument("--type", choices=("issue", "pr"), default=None, help="Resolve numeric task as issue or PR.")
    open_cmd.add_argument("--no-app", action="store_true", help="Print handoff paths without launching Codex Desktop.")
    open_cmd.add_argument("--print-prompt", action="store_true", help="Print prompt.md after the handoff paths.")
    open_cmd.set_defaults(func=command_open)

    webhook = subparsers.add_parser("webhook", help="Serve signed Gitea webhooks and trigger local review jobs.")
    webhook.add_argument(
        "--env",
        type=Path,
        default=None,
        help="Webhook env file. Default: $MORAS_GITEA_WEBHOOK_ENV or gitea-webhook.env under runner home.",
    )
    webhook.add_argument("--host", default=None, help="Override listener host from env.")
    webhook.add_argument("--port", type=int, default=None, help="Override listener port from env.")
    webhook.add_argument("--init-env", action="store_true", help="Create the local webhook env file if missing.")
    webhook.add_argument("--send-test", action="store_true", help="Send a signed local bridge_test webhook.")
    webhook.add_argument("--test-url", default=None, help="Override test webhook URL for --send-test.")
    webhook.set_defaults(func=command_webhook)

    sync_reviews = subparsers.add_parser(
        "sync-review-requests",
        help="Catch up missed PR review-request webhooks by polling open PRs.",
    )
    sync_reviews.add_argument(
        "--env",
        type=Path,
        default=None,
        help="Webhook env file. Default: $MORAS_GITEA_WEBHOOK_ENV or gitea-webhook.env under runner home.",
    )
    sync_reviews.add_argument("--repo", action="append", help="Repo slug to poll. Can be passed more than once.")
    sync_reviews.add_argument("--limit", type=int, default=None, help="Maximum open PRs to inspect per repo.")
    sync_reviews.add_argument(
        "--runtime",
        choices=("auto", "claude", "codex", "none"),
        default=None,
        help="Override runtime for catch-up reviews.",
    )
    sync_reviews.add_argument("--no-post", action="store_true", help="Do not post successful catch-up PR reviews.")
    sync_reviews.set_defaults(func=command_sync_review_requests)

    monitor = subparsers.add_parser(
        "monitor",
        help="Poll Gitea issues/PRs and track local change snapshots.",
    )
    monitor.add_argument(
        "--env",
        type=Path,
        default=None,
        help="Webhook env file. Default: $MORAS_GITEA_WEBHOOK_ENV or gitea-webhook.env under runner home.",
    )
    monitor.add_argument("--repo", action="append", help="Repo slug to monitor. Can be passed more than once.")
    monitor.add_argument("--limit", type=int, default=None, help="Maximum open issues/PRs to inspect per repo.")
    monitor.add_argument("--interval", type=int, default=None, help="Polling interval in seconds. Default: env or 10.")
    monitor.add_argument("--once", action="store_true", help="Run one scan and exit.")
    monitor.add_argument(
        "--runtime",
        choices=("auto", "claude", "codex", "none"),
        default=None,
        help="Override runtime for review jobs queued by monitoring.",
    )
    monitor.add_argument("--no-pr-review", action="store_true", help="Track changes without queueing PR reviews.")
    monitor.add_argument("--no-post", action="store_true", help="Do not post successful monitored PR reviews.")
    monitor.set_defaults(func=command_monitor)

    changes = subparsers.add_parser("changes", help="Show locally tracked issue/PR changes.")
    changes.add_argument(
        "--env",
        type=Path,
        default=None,
        help="Webhook env file. Default: $MORAS_GITEA_WEBHOOK_ENV or gitea-webhook.env under runner home.",
    )
    changes.add_argument("--limit", type=int, default=30)
    changes.add_argument("--items", action="store_true", help="List current tracked items instead of change events.")
    changes.add_argument("--type", choices=("issue", "pr"), default=None, help="Filter --items output.")
    changes.set_defaults(func=command_changes)

    ui = subparsers.add_parser("ui", help="Serve the local runner dashboard.")
    ui.add_argument(
        "--env",
        type=Path,
        default=None,
        help="Webhook env file. Default: $MORAS_GITEA_WEBHOOK_ENV or gitea-webhook.env under runner home.",
    )
    ui.add_argument("--host", default="127.0.0.1", help="UI bind host. Default: 127.0.0.1.")
    ui.add_argument("--port", type=int, default=DEFAULT_UI_PORT, help=f"UI port. Default: {DEFAULT_UI_PORT}.")
    ui.set_defaults(func=command_ui)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return int(args.func(args))
    except DemoError as exc:
        print(f"moras-issue-demo: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
