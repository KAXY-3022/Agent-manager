# Local-only Gitea webhook runner settings.
# Copy to gitea-webhook.env and set MORAS_GITEA_WEBHOOK_SECRET to the Gitea webhook secret.

MORAS_GITEA_WEBHOOK_SECRET=change-me
MORAS_GITEA_USERNAME=your-gitea-username
MORAS_GITEA_WEBHOOK_HOST=127.0.0.1
MORAS_GITEA_WEBHOOK_PORT=48731

# Runtime used by webhook-triggered jobs.
MORAS_GITEA_WEBHOOK_RUNTIME=codex

# Issue jobs default to local artifacts only unless enabled.
MORAS_GITEA_ISSUE_AUTO_POST=false

# PR review jobs post the normalized review comment when the runtime succeeds.
MORAS_GITEA_PR_AUTO_POST=true

MORAS_GITEA_FAILED_RETRY_LIMIT=0
MORAS_GITEA_WEBHOOK_JOB_TIMEOUT_SECONDS=14400

# Legacy PR-review-only poller. The general monitor below supersedes it.
MORAS_GITEA_PR_REVIEW_POLL_SECONDS=0
MORAS_GITEA_PR_REVIEW_POLL_REPOS=owner/repo
MORAS_GITEA_PR_REVIEW_POLL_LIMIT=50

# Poll issues and PRs, keep a local SQLite tracking list, and queue requested PR reviews.
MORAS_GITEA_MONITOR_SECONDS=10
MORAS_GITEA_MONITOR_REPOS=owner/repo
MORAS_GITEA_MONITOR_LIMIT=50
MORAS_GITEA_MONITOR_PR_REVIEWS=true

MORAS_GITEA_WEBHOOK_STATE_DB=state/gitea-webhook.sqlite3
MORAS_GITEA_WEBHOOK_LOG=logs/gitea-webhook.log
