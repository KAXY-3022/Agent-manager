# Local-only Gitea webhook runner settings.
# Copy to gitea-webhook.env and set A2A_GITEA_WEBHOOK_SECRET to the Gitea webhook secret.

A2A_GITEA_WEBHOOK_SECRET=change-me
A2A_GITEA_USERNAME=your-gitea-username
A2A_GITEA_WEBHOOK_HOST=127.0.0.1
A2A_GITEA_WEBHOOK_PORT=48731

# Runtime used by webhook-triggered jobs.
A2A_GITEA_WEBHOOK_RUNTIME=codex

# Issue jobs default to local artifacts only unless enabled.
A2A_GITEA_ISSUE_AUTO_POST=false

# PR review jobs post the normalized review comment when the runtime succeeds.
A2A_GITEA_PR_AUTO_POST=true

A2A_GITEA_FAILED_RETRY_LIMIT=0
A2A_GITEA_WEBHOOK_JOB_TIMEOUT_SECONDS=14400

# Legacy PR-review-only poller. The general monitor below supersedes it.
A2A_GITEA_PR_REVIEW_POLL_SECONDS=0
A2A_GITEA_PR_REVIEW_POLL_REPOS=owner/repo
A2A_GITEA_PR_REVIEW_POLL_LIMIT=50

# Poll issues and PRs and keep a local SQLite tracking list. PR reviews are queued manually.
A2A_GITEA_MONITOR_SECONDS=60
A2A_GITEA_MONITOR_REPOS=owner/repo
A2A_GITEA_MONITOR_LIMIT=50
A2A_GITEA_MONITOR_PR_REVIEWS=true

A2A_GITEA_WEBHOOK_STATE_DB=state/gitea-webhook.sqlite3
A2A_GITEA_WEBHOOK_LOG=logs/gitea-webhook.log
